# ============================================
# AI_Blogger 环境变量配置模板
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ⚠️ .env 文件已加入 .gitignore，请勿提交到版本库
# ============================================

# ---------- DeepSeek 大模型 API ----------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ---------- 知乎平台 ----------
ZHIHU_USERNAME=your-zhihu-username
ZHIHU_PASSWORD=your-zhihu-password

# ---------- 微博平台 ----------
WEIBO_USERNAME=your-weibo-username
WEIBU_PASSWORD=your-weibo-password

# ---------- 通义千问图片生成（可选）----------
QWEN_API_KEY=
